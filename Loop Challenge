let num = parseInt(prompt("Enter a number"));

for (let i = 1; i <= num; i++) {
    if (i === num) {
        console.log(i);        
    } else {
        process.stdout.write(i + ","); 
    }
}
// printing the even number
let num = prompt("Enter a number");
let n = Number(num);

for (let i = 1; i <= n; i++) {
    if (i % 2 === 0) {
        console.log(i);
    }
}
// printing the sum of numbers 
let sum = 0;

for (let i = 1; i <= 100; i++) {
    sum += i;
}

console.log("Sum:", sum);

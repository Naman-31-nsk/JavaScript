<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DOM Manipulation</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center h-screen">

  <div class="bg-white p-8 rounded-xl shadow-lg text-center">
    <p id="text" class="text-lg text-gray-700 mb-4">
      This is original text
    </p>

    <button id="btn"
      class="bg-blue-500 text-white px-5 py-2 rounded-lg hover:bg-blue-600 transition">
      Click Me
    </button>
  </div>

  <!-- JavaScript inside same file -->
  <script>
    let button = document.querySelector("#btn");
    let para = document.querySelector("#text");

    button.addEventListener("click", function() {
      para.innerText = "Text has been changed!";
      para.classList.add("text-blue-500", "font-bold");
    });
  </script>

</body>
</html>
